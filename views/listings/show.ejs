<% layout("/layouts/boilerplate") %>

<div class="container mt-5 mb-5">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <!-- Heading -->
            <h2 class="fw-bold mb-4">
                <%= listing.title %>
            </h2>

            <!-- Card -->
            <div class="card border-0 shadow rounded-4 overflow-hidden">

                <!-- Image -->
                <img 
                    src="<%= listing.image.url %>" 
                    class="card-img-top show-img"
                    alt="listing_image"
                    style="height: 28rem; object-fit: cover;"
                >

                <!-- Body -->
                <div class="card-body p-4">

                    <!-- Host -->
                    <p class="text-muted mb-3">
                        Hosted in <%= listing.location %>, <%= listing.country %>
                    </p>

                    <!-- Description -->
                    <p class="card-text fs-5">
                        <%= listing.description %>
                    </p>

                    <!-- Price -->
                    <h4 class="mt-4 fw-bold">
                        ₹ <%= listing.price.toLocaleString("en-IN") %>
                        <span class="fs-6 text-muted fw-normal">
                            / night
                        </span>
                    </h4>

                    <!-- Location -->
                    <div class="mt-3">

                        <span class="badge bg-light text-dark border p-2 fs-6">
                            📍 <%= listing.location %>, <%= listing.country %>
                        </span>

                    </div>

                    <!-- Buttons -->
                    <div class="d-flex gap-3 mt-5">

                        <!-- Edit -->
                        <a 
                            href="/listings/<%= listing._id %>/edit"
                            class="btn btn-dark px-4 rounded-pill"
                        >
                            Edit
                        </a>

                        <!-- Delete -->
                        <form 
                            method="POST"
                            action="/listings/<%= listing._id %>?_method=DELETE"
                        >

                            <button class="btn btn-outline-danger rounded-pill px-4">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>